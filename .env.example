# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP Configuration for Contact Inquiry Email Notifications
# Used by Nodemailer to send admin notifications when new inquiries arrive.
# For Gmail: use smtp.gmail.com:587 with an App Password (not your regular password).
# The code supports BOTH naming conventions — set at least one pair:
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-char-app-password"
SMTP_FROM_NAME="UNI-VERSE CMS"
# Alternative names (aliases — either pair works on Render):
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-16-char-app-password"
